<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="shortcut icon" type="image/x-icon" href="pharmacy.ico">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mein Lounge — Farouk Ashraf</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <script src="Assets/js/theme-preloader.js"></script>
  <link rel="stylesheet" href="Assets/css/style.css">
</head>
<body data-root-path="./">

<div id="pageLoader" class="page-loader">
  <div class="loader-content">
    <span class="loader-logo">Farouk Ashraf</span>
    <div class="loader-spinner-bar"></div>
  </div>
</div>

<!-- HERO -->
<section class="hero blog-hero">
  <div class="sacred-geometry">
    <svg viewBox="0 0 1000 600" preserveAspectRatio="xMidYEnd meet">
      <polygon points="50,550 280,180 510,550" fill="none" stroke="currentColor" stroke-width="0.75"/>
      <polygon points="380,550 560,240 740,550" fill="none" stroke="currentColor" stroke-width="0.75"/>
      <polygon points="660,550 780,340 900,550" fill="none" stroke="currentColor" stroke-width="0.75"/>
      <line x1="0" y1="550" x2="1000" y2="550" stroke="currentColor" stroke-width="1"/>
    </svg>
  </div>

  <div class="hero-left">
    <span class="hero-tag hero-reveal">MEIN LOUNGE</span>
    <h1 class="hero-reveal">Shower <em>Thoughts</em></h1>
    <p class="hero-bio hero-reveal">
      A directory of thoughts, analysis, and essays. Here, I write about the intersection of <strong>whateever I feel is important at the moment</strong>, and other subjects I find compelling.
    </p>
  </div>
  <div class="hero-right hero-reveal" style="display:flex; justify-content:center; align-items:center;">
    <span class="Rx" style="position:static; font-size:clamp(6rem, 15vw, 16rem); opacity:0.8;">✍︎</span>
  </div>
</section>

<!-- BLOG LISTINGS -->
<section class="blog-list-section">
  <div class="sec-meta">
    <span class="sec-num">01</span>
    <span class="sec-rule"></span>
    <span class="sec-name">Written Logs</span>
  </div>
  <h2>Recent <em>Thoughts</em></h2>
  
  <div class="blog-grid">
    <!-- Blog Card 1 -->
    <a href="blogs/the-alignment-problem.html" class="blog-card reveal">
      <div class="blog-card-meta">
        <span class="blog-date">July 2, 2026</span>
        <span class="blog-tag">Thoughts on AI</span>
      </div>
      <h3>The Alignment Problem</h3>
      <p class="blog-excerpt">
        An exploration of human morality, the son/ father relationship between us and the machines, and how we might affect the evolution of non-human intelligence.
      </p>
      <span class="blog-read-more">Read Entry →</span>
    </a>

    <!-- Blog Card 2 (Placeholder) -->
    <div class="blog-card placeholder reveal">
      <div class="blog-card-meta">
        <span class="blog-date">Coming Soon</span>
        <span class="blog-tag">Future Essays</span>
      </div>
      <h3>Awaiting the next spark...</h3>
      <p class="blog-excerpt">
        This space is reserved for future reflections, experiences in healthcare coordination, and emerging AI alignment concepts.
      </p>
      <span class="blog-read-more" style="opacity:0.4;">Under Construction</span>
    </div>
  </div>
</section>

<script src="Assets/js/main.js"></script>
</body>
</html>
