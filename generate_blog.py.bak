#!/usr/bin/env python3
import os
import re
import datetime
import sys
import shutil

# --- CONFIGURATION & CONSTANTS ---
TEMPLATE_PATH = "blogs/template.html"
BLOG_LIST_PATH = "blog.html"
BLOGS_DIR = "blogs"

# ANSI Colors for a "neat" TUI
CLR_RESET = "\033[0m"
CLR_BOLD = "\033[1m"
CLR_RUST = "\033[38;2;184;92;56m"
CLR_RUST_LIGHT = "\033[38;2;212;133;106m"
CLR_MUTE = "\033[38;2;138;128;116m"
CLR_PAPER = "\033[38;2;245;240;232m"
CLR_GREEN = "\033[32m"
CLR_RED = "\033[31m"
CLR_YELLOW = "\033[33m"
CLR_CYAN = "\033[36m"

def print_banner():
    banner = f"""
{CLR_RUST}{CLR_BOLD}
   __  ___     _      __                          
  /  |/  /__  (_)__  / / ___  __ _____  ___ ____ 
 / /|_/ / _ \/ / _ \/ /_/ _ \/ // / _ \/ _ `/ -_)
/_/  /_/\___/_/_//_/____\___/\_,_/_//_/\_, /\__/ 
                                      /___/      
{CLR_MUTE}   >> BLOG GENERATOR V2.0 PRO // FAROUK ASHRAF{CLR_RESET}
    """
    print(banner)

def slugify(text):
    text = text.lower()
    text = re.sub(r'[^\w\s-]', '', text)
    text = re.sub(r'[\s_-]+', '-', text)
    return text.strip('-')

def parse_inline_markdown(text):
    # Lightweight inline markdown parser
    # Bold: **bold**
    text = re.sub(r'\*\*(.*?)\*\*', r'<strong>\1</strong>', text)
    # Italic: *italic*
    text = re.sub(r'\*(.*?)\*', r'<em>\1</em>', text)
    # Inline links: [text](url)
    text = re.sub(r'\[(.*?)\]\((.*?)\)', r'<a href="\2" target="_blank">\1</a>', text)
    return text

def get_input(prompt, color=CLR_RUST_LIGHT, bold=True, default=None):
    prefix = f"{CLR_BOLD}{color}" if bold else f"{color}"
    default_str = f" [{default}]" if default else ""
    try:
        val = input(f"{prefix}{prompt}{default_str}:{CLR_RESET} ")
        if not val.strip() and default:
            return default
        return val.strip()
    except EOFError:
        print("\nExiting...")
        sys.exit(0)

def manage_blocks(blocks):
    while True:
        os.system('clear' if os.name == 'posix' else 'cls')
        print_banner()
        print(f"\n{CLR_BOLD}{CLR_RUST}--- REVIEW CURRENT STORY BLOCKS ---{CLR_RESET}")
        
        if not blocks:
            print(f"{CLR_MUTE}(No blocks added yet){CLR_RESET}")
            get_input("Press Enter to return to menu", CLR_MUTE)
            return blocks

        for i, block in enumerate(blocks):
            # Extract clean preview of block type and content
            btype = block['type'].upper()
            snippet = block['raw_text'][:60] + "..." if len(block['raw_text']) > 60 else block['raw_text']
            print(f"[{CLR_CYAN}{i}{CLR_RESET}] {CLR_BOLD}{CLR_RUST_LIGHT}{btype:<10}{CLR_RESET} | {CLR_MUTE}{snippet}{CLR_RESET}")

        print(f"\n{CLR_BOLD}Management Options:{CLR_RESET} [d]elete | [r]eorder | [e]dit | [b]ack")
        act = get_input("Choice:").lower()
        
        if act == 'b':
            break
        elif act == 'd':
            idx = get_input("Enter block index to delete:")
            try:
                idx = int(idx)
                if 0 <= idx < len(blocks):
                    removed = blocks.pop(idx)
                    print(f"{CLR_GREEN}Removed {removed['type']} block.{CLR_RESET}")
                else:
                    print(f"{CLR_RED}Index out of bounds.{CLR_RESET}")
            except ValueError:
                print(f"{CLR_RED}Invalid index.{CLR_RESET}")
            get_input("Press Enter to continue", CLR_MUTE)
        elif act == 'r':
            idx1 = get_input("Enter index of block to move:")
            idx2 = get_input("Enter target index:")
            try:
                idx1, idx2 = int(idx1), int(idx2)
                if 0 <= idx1 < len(blocks) and 0 <= idx2 < len(blocks):
                    # Swap/reorder
                    block = blocks.pop(idx1)
                    blocks.insert(idx2, block)
                    print(f"{CLR_GREEN}Moved block.{CLR_RESET}")
                else:
                    print(f"{CLR_RED}Index out of bounds.{CLR_RESET}")
            except ValueError:
                print(f"{CLR_RED}Invalid indices.{CLR_RESET}")
            get_input("Press Enter to continue", CLR_MUTE)
        elif act == 'e':
            idx = get_input("Enter block index to edit:")
            try:
                idx = int(idx)
                if 0 <= idx < len(blocks):
                    block = blocks[idx]
                    if block['type'] in ['paragraph', 'heading', 'quote']:
                        print(f"\n{CLR_BOLD}Current Content:{CLR_RESET}\n{block['raw_text']}")
                        new_content = get_input("Enter new content (or leave empty to keep current):", CLR_PAPER, False)
                        if new_content:
                            block['raw_text'] = new_content
                            # Re-generate html
                            parsed = parse_inline_markdown(new_content)
                            if block['type'] == 'paragraph':
                                block['html'] = f"    <p>\n      {parsed}\n    </p>"
                            elif block['type'] == 'heading':
                                block['html'] = f"    <h2>{parsed}</h2>"
                            elif block['type'] == 'quote':
                                block['html'] = f"    <blockquote>\n      \"{parsed}\"\n    </blockquote>"
                            print(f"{CLR_GREEN}Block updated successfully.{CLR_RESET}")
                    else:
                        print(f"{CLR_YELLOW}Editing media blocks is not supported. Please delete and recreate.{CLR_RESET}")
                else:
                    print(f"{CLR_RED}Index out of bounds.{CLR_RESET}")
            except ValueError:
                print(f"{CLR_RED}Invalid index.{CLR_RESET}")
            get_input("Press Enter to continue", CLR_MUTE)

    return blocks

def main():
    os.system('clear' if os.name == 'posix' else 'cls')
    print_banner()

    # 1. Metadata Collection
    title = get_input("Enter Blog Title")
    if not title:
        print(f"{CLR_RED}Title cannot be empty.{CLR_RESET}")
        return

    category = get_input("Enter Category", default="Thoughts")
    excerpt = get_input("Enter Excerpt (for the listing card)")
    
    date_now = datetime.datetime.now().strftime("%B %d, %Y")
    iso_date = datetime.datetime.now().strftime("%Y-%m-%d")
    
    slug = slugify(title)
    file_path = os.path.join(BLOGS_DIR, f"{slug}.html")

    if os.path.exists(file_path):
        confirm = get_input(f"File {file_path} already exists. Overwrite? (y/n)", CLR_RED, default="n")
        if confirm.lower() != 'y':
            return

    # 2. Content Block Loop
    blocks = []
    print(f"\n{CLR_BOLD}{CLR_RUST}--- CONTENT BUILDER ---{CLR_RESET}")
    print(f"{CLR_MUTE}Add blocks to your story. Support inline Markdown formatting (e.g. **bold**, *italic*, [link](url)).{CLR_RESET}")
    
    while True:
        print(f"\n{CLR_BOLD}Options:{CLR_RESET} [p]aragraph | [h]eading | [q]uote | [i]mage | [v]ideo | [m]usic | [r]eview | [f]inish")
        choice = get_input("Choice").lower()

        if choice in ['f', 'finish']:
            if not blocks:
                confirm = get_input("Your post is empty. Finish anyway? (y/n)", CLR_YELLOW, default="n")
                if confirm.lower() != 'y':
                    continue
            break
        elif choice in ['r', 'review']:
            blocks = manage_blocks(blocks)
        elif choice in ['p', 'paragraph']:
            content = get_input("Type paragraph text", CLR_PAPER, False)
            if content:
                parsed = parse_inline_markdown(content)
                blocks.append({
                    'type': 'paragraph',
                    'raw_text': content,
                    'html': f"    <p>\n      {parsed}\n    </p>"
                })
        elif choice in ['h', 'heading']:
            content = get_input("Type heading text", CLR_PAPER, False)
            if content:
                parsed = parse_inline_markdown(content)
                blocks.append({
                    'type': 'heading',
                    'raw_text': content,
                    'html': f"    <h2>{parsed}</h2>"
                })
        elif choice in ['q', 'quote']:
            content = get_input("Type quote text", CLR_PAPER, False)
            if content:
                parsed = parse_inline_markdown(content)
                blocks.append({
                    'type': 'quote',
                    'raw_text': content,
                    'html': f"    <blockquote>\n      \"{parsed}\"\n    </blockquote>"
                })
        elif choice in ['i', 'image']:
            src = get_input("Image Path (relative to blogs/, e.g., ../Assets/portrait.jpg)", CLR_PAPER, False)
            
            # Simple validation check on local asset path
            abs_src_check = os.path.abspath(os.path.join(BLOGS_DIR, src))
            if not os.path.exists(abs_src_check):
                print(f"{CLR_YELLOW}⚠️  Warning: Local asset path '{src}' does not exist relative to 'blogs/' directory.{CLR_RESET}")
                cont = get_input("Use path anyway? (y/n)", CLR_YELLOW, default="y")
                if cont.lower() != 'y':
                    continue

            caption = get_input("Caption (optional)", CLR_MUTE, False)
            img_html = f"    <figure>\n      <img src=\"{src}\" alt=\"{title}\">"
            if caption:
                img_html += f"\n      <figcaption>{caption}</figcaption>"
            img_html += "\n    </figure>"
            blocks.append({
                'type': 'image',
                'raw_text': f"Src: {src} | Cap: {caption}",
                'html': img_html
            })
        elif choice in ['v', 'video']:
            print(f"{CLR_MUTE}Paste the YouTube/Vimeo embed code (iframe):{CLR_RESET}")
            iframe = get_input("Embed Code", CLR_PAPER, False)
            if iframe:
                blocks.append({
                    'type': 'video',
                    'raw_text': "Iframe Embed Code",
                    'html': f"    <div class=\"video-container\">\n      {iframe}\n    </div>"
                })
        elif choice in ['m', 'music']:
            print(f"{CLR_MUTE}Paste the Spotify/SoundCloud embed code (iframe):{CLR_RESET}")
            iframe = get_input("Embed Code", CLR_PAPER, False)
            if iframe:
                blocks.append({
                    'type': 'music',
                    'raw_text': "Iframe Embed Code",
                    'html': f"    <div class=\"media-embed\">\n      {iframe}\n    </div>"
                })
        else:
            print(f"{CLR_RED}Invalid choice.{CLR_RESET}")

    full_content = "\n\n".join([b['html'] for b in blocks])

    # 3. Generate Blog Page
    print(f"\n{CLR_BOLD}{CLR_RUST}--- GENERATING FILES ---{CLR_RESET}")
    
    try:
        with open(TEMPLATE_PATH, "r") as f:
            template = f.read()
    except FileNotFoundError:
        print(f"{CLR_RED}Error: {TEMPLATE_PATH} not found.{CLR_RESET}")
        return

    # Replacements
    # 1. Page Title
    page = re.sub(r'<title>.*?</title>', f'<title>{title} — Farouk Ashraf</title>', template)
    # 2. Meta Description
    page = re.sub(r'<meta name="description" content=".*?">', f'<meta name="description" content="{excerpt}">', page)
    # 3. Category
    page = re.sub(r'<span class="hero-tag">.*?</span>', f'<span class="hero-tag">{category}</span>', page)
    # 4. Heading Title
    page = re.sub(r'<h1 class="blog-post-title">.*?</h1>', f'<h1 class="blog-post-title">{title}</h1>', page)
    # 5. Meta Data (Date)
    page = re.sub(r'Published on .*? — Written by Farouk Ashraf', f'Published on {date_now} — Written by Farouk Ashraf', page)
    # 6. Content Body
    body_pattern = r'(<div class="blog-content-body">).*?(</div>)'
    page = re.sub(body_pattern, rf'\1\n{full_content}\n  \2', page, flags=re.DOTALL)
    # 7. Canonical URL
    canonical = f'https://farouk-pharmd.github.io/website/blogs/{slug}.html'
    page = re.sub(r'<link rel="canonical" href=".*?">', f'<link rel="canonical" href="{canonical}">', page)
    # OG Tags
    page = re.sub(r'<meta property="og:url" content=".*?">', f'<meta property="og:url" content="{canonical}">', page)
    page = re.sub(r'<meta property="og:title" content=".*?">', f'<meta property="og:title" content="{title} — Farouk Ashraf">', page)
    page = re.sub(r'<meta property="og:description" content=".*?">', f'<meta property="og:description" content="{excerpt}">', page)
    # Twitter Tags
    page = re.sub(r'<meta name="twitter:title" content=".*?">', f'<meta name="twitter:title" content="{title} — Farouk Ashraf">', page)
    page = re.sub(r'<meta name="twitter:description" content=".*?">', f'<meta name="twitter:description" content="{excerpt}">', page)
    # Published Time
    page = re.sub(r'<meta property="article:published_time" content=".*?">', f'<meta property="article:published_time" content="{iso_date}">', page)

    with open(file_path, "w") as f:
        f.write(page)
    print(f"{CLR_GREEN}✔ Created {file_path}{CLR_RESET}")

    # 4. Update blog.html
    try:
        with open(BLOG_LIST_PATH, "r") as f:
            list_page = f.read()
        
        # Backup
        with open(f"{BLOG_LIST_PATH}.bak", "w") as f:
            f.write(list_page)

        # Build Card
        new_card = f"""
    <a href="blogs/{slug}.html" class="blog-card reveal">
      <div class="blog-card-meta">
        <span class="blog-date">{date_now}</span>
        <span class="blog-tag">{category}</span>
      </div>
      <h3>{title}</h3>
      <p class="blog-excerpt">
        {excerpt}
      </p>
      <span class="blog-read-more">Read Entry →</span>
    </a>"""

        grid_pattern = r'(<div class="blog-grid">)'
        if re.search(grid_pattern, list_page):
            updated_list = re.sub(grid_pattern, rf'\1{new_card}', list_page)
            with open(BLOG_LIST_PATH, "w") as f:
                f.write(updated_list)
            print(f"{CLR_GREEN}✔ Updated {BLOG_LIST_PATH} with new card{CLR_RESET}")
        else:
            print(f"{CLR_RED}Could not find blog-grid in {BLOG_LIST_PATH}. Manual update required.{CLR_RESET}")

    except Exception as e:
        print(f"{CLR_RED}Error updating blog list: {e}{CLR_RESET}")

    print(f"\n{CLR_BOLD}{CLR_GREEN}Success! Enjoy your new blog post.{CLR_RESET}")

if __name__ == "__main__":
    main()
